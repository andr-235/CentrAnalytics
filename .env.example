POSTGRES_DB=centranalytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_IMAGE=postgres:17

JWT_SECRET=replace-with-base64-secret
JWT_EXPIRATION=86400000
APP_PORT=8080

INTEGRATION_ENABLED=true
VK_GROUP_ID=0
VK_SECRET=
VK_CONFIRMATION_CODE=
VK_ACCESS_TOKEN=
VK_USER_ACCESS_TOKEN=
VK_WEBHOOK_PATH=/api/integrations/webhooks/vk
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_REQUEST_TIMEOUT=5s
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/api/integrations/webhooks/telegram
TELEGRAM_BOT_USERNAME=

TELEGRAM_USER_ENABLED=true
TELEGRAM_USER_API_ID=your_telegram_api_id
TELEGRAM_USER_API_HASH=your_telegram_api_hash
TELEGRAM_USER_DATABASE_DIR=/app/.tdlib/db
TELEGRAM_USER_FILES_DIR=/app/.tdlib/files
TELEGRAM_USER_SYSTEM_LANGUAGE_CODE=en
TELEGRAM_USER_DEVICE_MODEL=CentrAnalytics
TELEGRAM_USER_SYSTEM_VERSION=server
TELEGRAM_USER_APPLICATION_VERSION=1.0.0
