POSTGRES_DB=centranalytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_IMAGE=postgres:17

# Generate JWT_SECRET: openssl rand -base64 64
# Must be at least 64 bytes for HS512
JWT_SECRET=replace-with-base64-secret
JWT_EXPIRATION=86400000
FRONTEND_PORT=18080

INTEGRATION_ENABLED=true
VK_GROUP_ID=0
VK_ACCESS_TOKEN=
VK_USER_ACCESS_TOKEN=
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_REQUEST_TIMEOUT=5s
VK_AUTO_COLLECTION_ENABLED=false
VK_AUTO_COLLECTION_REGION=
VK_AUTO_COLLECTION_GROUP_SEARCH_LIMIT=25
VK_AUTO_COLLECTION_POST_LIMIT=10
VK_AUTO_COLLECTION_COMMENT_POST_LIMIT=5
VK_AUTO_COLLECTION_COMMENT_LIMIT=20
VK_AUTO_COLLECTION_MODE=HYBRID
VK_AUTO_COLLECTION_FIXED_DELAY_MS=900000
TELEGRAM_BOT_USERNAME=

TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_AUTH_GATEWAY_ENABLED=true
TELEGRAM_AUTH_GATEWAY_BASE_URL=http://telegram-auth-gateway:8091
TELEGRAM_AUTH_GATEWAY_CONNECT_TIMEOUT=5s
TELEGRAM_AUTH_GATEWAY_READ_TIMEOUT=30s
TELEGRAM_PROXY_IMAGE=ghcr.io/xtls/xray-core:latest
TELEGRAM_PROXY_CONFIG_PATH=./telegram-proxy/config.json
TELEGRAM_AUTH_GATEWAY_PROXY_ENABLED=false
TELEGRAM_AUTH_GATEWAY_PROXY_TRANSPORT=socks5
TELEGRAM_AUTH_GATEWAY_PROXY_HOST=
TELEGRAM_AUTH_GATEWAY_PROXY_PORT=10808
TELEGRAM_AUTH_GATEWAY_PROXY_USERNAME=
TELEGRAM_AUTH_GATEWAY_PROXY_PASSWORD=
TELEGRAM_AUTH_GATEWAY_MTPROTO_PROXY_SECRET=
TELEGRAM_COLLECTOR_ENABLED=true
BACKEND_INGESTION_BASE_URL=http://app:8080
# Generate internal token: openssl rand -hex 32
TELEGRAM_GATEWAY_INGESTION_ENABLED=true
TELEGRAM_GATEWAY_INGESTION_INTERNAL_TOKEN=replace-with-internal-token
WAPPI_WEBHOOK_PATH=/api/integrations/webhooks/wappi
